mixin detailTable(rows)
  table(width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;")
    each row, index in rows
      - const border = index === rows.length - 1 ? '' : 'border-bottom: 1px solid #e2e8f0;';
      tr
        td(style=`padding: 12px 0; ${border}`)
          span(style="color: #6b7a90; font-size: 14px;")= row.label
        td(style=`padding: 12px 0; ${border} text-align: right;`)
          - const valueStyle = `color: ${row.color || '#1a1a1a'}; font-size: ${row.monospace ? '13px' : '14px'}; ${row.monospace ? 'font-family: monospace;' : ''} ${row.strong ? 'font-weight: 700;' : ''}`;
          if row.href
            a(href=row.href style=`color: ${brandGreen}; font-size: 14px; text-decoration: none;`)= row.value
          else
            span(style=valueStyle)= row.value
