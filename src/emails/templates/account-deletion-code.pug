extends ../layouts/base.pug

block content
  h1 Confirm Account Deletion
  p.subtitle Account Deletion Request
  p.greeting Hi #{name},
  p We received a request to permanently delete your #{appName} account. If you made this request, use the verification code below to confirm:
  .code-box(style=`background-color: ${brandBgDark}; border: 2px solid #ef4444; border-radius: 10px; padding: 24px; text-align: center; margin: 28px 0;`)
    span(style="font-size: 36px; font-weight: 700; letter-spacing: 8px; color: #ef4444; font-family: 'Courier New', monospace;")= code
  .warning-box
    p
      strong This code expires in 10 minutes.
      |  If you did not request this deletion, please ignore this email and secure your account by changing your password immediately.
  .warning-box(style="background: #fee2e2; border-left-color: #ef4444;")
    p(style="color: #991b1b;")
      strong Warning:
      |  Account deletion is permanent. Your profile, settings, and preferences will be removed. However, transaction records will be retained for regulatory compliance.
