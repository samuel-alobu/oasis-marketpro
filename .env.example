# ============================================
# RFM TRADEPRO - ENVIRONMENT VARIABLES
# ============================================

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Oasis MarketPro"

# Database
MONGODB_URI=mongodb://localhost:27017/rfmtradepro

# Authentication (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=add-your-super-secret-key-change-in-production

# JWT
JWT_SECRET=add-your-jwt-secret-key-change-in-production

# Email (Resend)
RESEND_API_KEY=re_add_your_resend_api_key
EMAIL_FROM="Oasis MarketPro <noreply@oasismarketpro.com>"

# CoinGecko API (Free tier - 30 calls/min)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Admin Configuration
ADMIN_EMAIL=admin@oasismarketpro.com
ADMIN_PASSWORD=admin123456

# Cloudinary (for image/PDF uploads)
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Feature Flags
ENABLE_WALLET_CONNECT=true
ENABLE_COPY_TRADING=true
ENABLE_REAL_ESTATE=true
ENABLE_STAKING=true
